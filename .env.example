# ============================================================================
# LOC8 Application - Environment Configuration Template
# ============================================================================
# Copy this file to .env and replace placeholder values with your actual configuration
# Used by: Backend (Python), Frontend (React), Docker containers, and Edge Functions
# ============================================================================

# ============================================================================
# PYTHON & RUNTIME CONFIGURATION (Backend)
# ============================================================================
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# ============================================================================
# BACKEND API CONFIGURATION
# ============================================================================
DEBUG=false
API_TITLE=PolyDeal API
API_VERSION=1.0.0
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
# Frontend API URL - adjust based on environment
# Development: http://localhost:8000/api
# Production: /api (proxied through Nginx)
VITE_API_BASE_URL=http://localhost:8000/api
VITE_APP_NAME=AI Outreach Intelligence Dashboard
VITE_USE_MOCK_DATA=false

# Analytics (optional)
# VITE_ANALYTICS_ID=your-analytics-id

# ============================================================================
# SECURITY
# ============================================================================
# Generate a random string using: openssl rand -base64 32
# OR: python -c 'import secrets; print(secrets.token_urlsafe(32))'
SECRET_KEY=your_secret_key_here_use_openssl_rand_-base64_32

# Allowed hosts for the backend API
ALLOWED_HOSTS=localhost,127.0.0.1,nginx,backend,frontend

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL database URL (if using external database)
# Format: postgresql://username:password@host:port/database_name
# DATABASE_URL=postgresql://user:password@localhost:5432/loc8_db

# Supabase (PostgreSQL + Functions)
# Get these from your Supabase project settings
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
VITE_SUPABASE_FUNCTION_URL=your_supabase_function_url_here

# ============================================================================
# AUTHENTICATION (Clerk)
# ============================================================================
# Get these from your Clerk Dashboard: https://clerk.com
# Clerk Frontend Key (for React app)
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# Clerk Backend Secret Key (for Python API)
CLERK_API_KEY=your_clerk_secret_key_here

# ============================================================================
# AI/ML SERVICES
# ============================================================================
# Anthropic Claude API
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_ADMIN_API_KEY=your_anthropic_admin_api_key_here

# Google Gemini API
# Get from: https://makersuite.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================================
# EXTERNAL INTEGRATIONS & SERVICES
# ============================================================================
# Gnews API - News data and insights
# Get from: https://gnews.io/
GNEWS_API_KEY=your_gnews_api_key_here

# Stripe - Payment processing
# Get from: https://stripe.com/
STRIPE_API_KEY=your_stripe_api_key_here

# Microsoft - Teams, Outlook, Office integrations
# Get from: https://azure.microsoft.com/
MICROSOFT_API_KEY=your_microsoft_api_key_here

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Development (localhost)
CORS_ORIGINS=http://localhost:3000,http://localhost,http://nginx,http://frontend
# Production - update with your domain(s)
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_HEADERS=*

# ============================================================================
# OPTIONAL SERVICES (Advanced)
# ============================================================================
# Redis - Caching and session management
# REDIS_URL=redis://redis:6379

# Celery - Task queue (for async jobs)
# CELERY_BROKER_URL=redis://redis:6379

# Sentry - Error tracking and monitoring
# SENTRY_DSN=https://key@sentry.io/project

# Email Configuration (if needed for notifications)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_password

# ============================================================================
# FEATURE FLAGS & API KEYS
# ============================================================================
API_KEY_ID=your_api_key_id_here
